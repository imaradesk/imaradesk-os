# =========================
# ImaraDesk Configuration
# =========================
# Copy this file to .env and update the values

# =========================
# Django Settings
# =========================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Application name displayed in the UI
APP_NAME=ImaraDesk

# Primary domain (without protocol)
PRIMARY_DOMAIN=localhost:8000

# =========================
# Database Configuration
# =========================
# Uncomment the block for your database driver:

# --- MySQL ---
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=imaradesk
# DB_USER=root
# DB_PASSWORD=your-password
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_OPTIONS_INIT_COMMAND=SET sql_mode='STRICT_TRANS_TABLES'

# --- PostgreSQL (default) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=imaradesk
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=127.0.0.1
DB_PORT=5432
# DB_OPTIONS_INIT_COMMAND=

# =========================
# Redis Configuration
# =========================
# Required for Celery background tasks
REDIS_URL=redis://localhost:6379/0

# =========================
# Email Configuration
# =========================
# SMTP settings for sending emails (notifications, password resets, etc.)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com
DEFAULT_FROM_NAME=ImaraDesk

# =========================
# CORS & CSRF Configuration
# =========================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# =========================
# Production Settings (optional)
# =========================
# Uncomment and configure for production deployment

# Cookie domains for multi-subdomain support
# SESSION_COOKIE_DOMAIN=.yourdomain.com
# CSRF_COOKIE_DOMAIN=.yourdomain.com
